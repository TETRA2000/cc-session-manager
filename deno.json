{
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.ns", "deno.window"]
  },
  "imports": {
    "hono": "jsr:@hono/hono@^4",
    "hono/deno": "jsr:@hono/hono@^4/deno",
    "hono/": "jsr:@hono/hono@^4/",
    "@std/path": "jsr:@std/path@^1",
    "@std/streams": "jsr:@std/streams@^1",
    "@std/cli": "jsr:@std/cli@^1",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "tasks": {
    "dev": "deno run --watch --allow-read=$HOME/.claude,. --allow-net=127.0.0.1:3456 --allow-env=HOME --deny-write=$HOME/.claude main.ts",
    "start": "deno run --allow-read=$HOME/.claude,$PROJECTS_ROOT,. --allow-write=$PROJECTS_ROOT --allow-run=claude,git --allow-net=127.0.0.1:3456 --allow-env=HOME,PROJECTS_ROOT --deny-write=$HOME/.claude main.ts",
    "check": "deno check main.ts",
    "test": "deno test --allow-read=$HOME/.claude,. --allow-env=HOME tests/"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
