#!/usr/bin/env bash
# Mock sbx CLI for E2E testing
# State stored in $MOCK_SBX_STATE_DIR (one JSON file per sandbox)
set -euo pipefail

STATE_DIR="${MOCK_SBX_STATE_DIR:?MOCK_SBX_STATE_DIR must be set}"

case "${1:-}" in
  --version)
    echo "sbx version 0.23.0"
    exit 0
    ;;

  create)
    shift
    NAME=""
    AGENT=""
    WORKSPACE=""
    # Parse arguments
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --name) NAME="$2"; shift 2 ;;
        claude|codex|shell) AGENT="$1"; shift ;;
        *)
          # First non-flag arg after agent is workspace
          if [[ -n "$AGENT" && -z "$WORKSPACE" ]]; then
            WORKSPACE="$1"
          fi
          shift
          ;;
      esac
    done
    if [[ -z "$NAME" || -z "$AGENT" ]]; then
      echo "Error: --name and agent are required" >&2
      exit 1
    fi
    if [[ -f "$STATE_DIR/$NAME" ]]; then
      echo "Error: Sandbox $NAME already exists" >&2
      exit 1
    fi
    echo "{\"agent\":\"$AGENT\",\"status\":\"running\",\"workspace\":\"${WORKSPACE:-/workspace}\"}" > "$STATE_DIR/$NAME"
    echo "$NAME"
    exit 0
    ;;

  ls)
    # Print tabular output matching real sbx ls format
    printf "%-24s%-8s%-9s%-25s%s\n" "SANDBOX" "AGENT" "STATUS" "PORTS" "WORKSPACE"
    for f in "$STATE_DIR"/*; do
      [[ -f "$f" ]] || continue
      NAME=$(basename "$f")
      AGENT=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d['agent'])" "$f" 2>/dev/null || echo "unknown")
      STATUS=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d['status'])" "$f" 2>/dev/null || echo "unknown")
      WORKSPACE=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d['workspace'])" "$f" 2>/dev/null || echo "")
      printf "%-24s%-8s%-9s%-25s%s\n" "$NAME" "$AGENT" "$STATUS" "" "$WORKSPACE"
    done
    exit 0
    ;;

  stop)
    NAME="${2:?sandbox name required}"
    if [[ ! -f "$STATE_DIR/$NAME" ]]; then
      echo "Error: No such sandbox: $NAME" >&2
      exit 1
    fi
    # Update status to stopped
    python3 -c "
import json, sys
f = sys.argv[1]
d = json.load(open(f))
d['status'] = 'stopped'
json.dump(d, open(f, 'w'))
" "$STATE_DIR/$NAME"
    echo "$NAME"
    exit 0
    ;;

  rm|remove)
    NAME="${2:?sandbox name required}"
    if [[ ! -f "$STATE_DIR/$NAME" ]]; then
      echo "Error: No such sandbox: $NAME" >&2
      exit 1
    fi
    rm "$STATE_DIR/$NAME"
    echo "$NAME"
    exit 0
    ;;

  exec)
    NAME="${2:?sandbox name required}"
    if [[ ! -f "$STATE_DIR/$NAME" ]]; then
      echo "Error: No such sandbox: $NAME" >&2
      exit 1
    fi
    STATUS=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d['status'])" "$STATE_DIR/$NAME")
    if [[ "$STATUS" != "running" ]]; then
      echo "Error: Sandbox $NAME is not running" >&2
      exit 1
    fi
    # Find the -- separator and execute everything after it
    shift 2  # remove "exec" and NAME
    while [[ $# -gt 0 && "$1" != "--" ]]; do
      shift  # skip flags like -it
    done
    if [[ $# -gt 0 && "$1" == "--" ]]; then
      shift  # skip the --
    fi
    if [[ $# -eq 0 ]]; then
      echo "Error: no command specified" >&2
      exit 1
    fi
    exec "$@"
    ;;

  secret)
    case "${2:-}" in
      ls)
        printf "%-11s%-12s%s\n" "SCOPE" "SERVICE" "SECRET"
        printf "%-11s%-12s%s\n" "(global)" "anthropic" "sk-ant-****...****43qy"
        exit 0
        ;;
      *)
        echo "Error: unknown secret subcommand: ${2:-}" >&2
        exit 1
        ;;
    esac
    ;;

  *)
    echo "Error: unknown command: ${1:-}" >&2
    exit 1
    ;;
esac
