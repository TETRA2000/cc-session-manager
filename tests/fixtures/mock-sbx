#!/usr/bin/env bash
# Mock sbx CLI for E2E testing
# State stored in $MOCK_SBX_STATE_DIR (one JSON file per sandbox)
set -euo pipefail

STATE_DIR="${MOCK_SBX_STATE_DIR:?MOCK_SBX_STATE_DIR must be set}"

# Simple JSON field extractor (avoids python3 dependency)
# Usage: json_get <file> <field>
json_get() {
  grep -o "\"$2\":\"[^\"]*\"" "$1" | head -1 | sed "s/\"$2\":\"//;s/\"$//"
}

# Simple JSON field updater
# Usage: json_set <file> <field> <value>
json_set() {
  local tmp="${1}.tmp"
  sed "s/\"$2\":\"[^\"]*\"/\"$2\":\"$3\"/" "$1" > "$tmp" && mv "$tmp" "$1"
}

case "${1:-}" in
  --version)
    echo "sbx version 0.23.0"
    exit 0
    ;;

  create)
    shift
    NAME=""
    AGENT=""
    WORKSPACE=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --name) NAME="$2"; shift 2 ;;
        --network-policy) shift 2 ;;
        claude|codex|shell) AGENT="$1"; shift ;;
        *)
          if [[ -n "$AGENT" && -z "$WORKSPACE" ]]; then
            WORKSPACE="$1"
          fi
          shift
          ;;
      esac
    done
    if [[ -z "$NAME" || -z "$AGENT" ]]; then
      echo "Error: --name and agent are required" >&2
      exit 1
    fi
    if [[ -f "$STATE_DIR/$NAME" ]]; then
      echo "Error: Sandbox $NAME already exists" >&2
      exit 1
    fi
    echo "{\"agent\":\"$AGENT\",\"status\":\"running\",\"workspace\":\"${WORKSPACE:-/workspace}\"}" > "$STATE_DIR/$NAME"
    echo "$NAME"
    exit 0
    ;;

  ls)
    printf "%-24s%-8s%-9s%-25s%s\n" "SANDBOX" "AGENT" "STATUS" "PORTS" "WORKSPACE"
    for f in "$STATE_DIR"/*; do
      [[ -f "$f" ]] || continue
      NAME=$(basename "$f")
      AGENT=$(json_get "$f" "agent" 2>/dev/null || echo "unknown")
      STATUS=$(json_get "$f" "status" 2>/dev/null || echo "unknown")
      WORKSPACE=$(json_get "$f" "workspace" 2>/dev/null || echo "")
      printf "%-24s%-8s%-9s%-25s%s\n" "$NAME" "$AGENT" "$STATUS" "" "$WORKSPACE"
    done
    exit 0
    ;;

  stop)
    NAME="${2:?sandbox name required}"
    if [[ ! -f "$STATE_DIR/$NAME" ]]; then
      echo "Error: No such sandbox: $NAME" >&2
      exit 1
    fi
    json_set "$STATE_DIR/$NAME" "status" "stopped"
    echo "$NAME"
    exit 0
    ;;

  rm|remove)
    NAME="${2:?sandbox name required}"
    if [[ ! -f "$STATE_DIR/$NAME" ]]; then
      echo "Error: No such sandbox: $NAME" >&2
      exit 1
    fi
    rm "$STATE_DIR/$NAME"
    echo "$NAME"
    exit 0
    ;;

  exec)
    NAME="${2:?sandbox name required}"
    if [[ ! -f "$STATE_DIR/$NAME" ]]; then
      echo "Error: No such sandbox: $NAME" >&2
      exit 1
    fi
    STATUS=$(json_get "$STATE_DIR/$NAME" "status")
    if [[ "$STATUS" != "running" ]]; then
      echo "Error: Sandbox $NAME is not running" >&2
      exit 1
    fi
    shift 2
    while [[ $# -gt 0 && "$1" != "--" ]]; do
      shift
    done
    if [[ $# -gt 0 && "$1" == "--" ]]; then
      shift
    fi
    if [[ $# -eq 0 ]]; then
      echo "Error: no command specified" >&2
      exit 1
    fi
    exec "$@"
    ;;

  secret)
    case "${2:-}" in
      ls)
        printf "%-11s%-12s%s\n" "SCOPE" "SERVICE" "SECRET"
        printf "%-11s%-12s%s\n" "(global)" "anthropic" "sk-ant-****...****43qy"
        exit 0
        ;;
      *)
        echo "Error: unknown secret subcommand: ${2:-}" >&2
        exit 1
        ;;
    esac
    ;;

  *)
    echo "Error: unknown command: ${1:-}" >&2
    exit 1
    ;;
esac
